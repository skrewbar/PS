{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "(gdb) Build and Debug Active File",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}.out",
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "MIMode": "gdb",
      "preLaunchTask": "g++ Build Active File"
    },
    {
      "name": "(lldb) Build and Debug Active File",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}.out",
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "MIMode": "lldb",
      "preLaunchTask": "g++ Build Active File (macOS)",
      "externalConsole": true
    },
    {
      "name": "(codelldb) Debug Active File",
      "type": "codelldb",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}.out",
      "cwd": "${fileDirname}"
    }
  ]
}
